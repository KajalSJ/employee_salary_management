# Copy this file to .env.local and fill in real values for local development.
# .env* is gitignored.

# Origin of the backend API. Used server-side only, by next.config.ts's
# rewrite of /api/:path* -> ${BACKEND_URL}/:path* (see CLAUDE.md's
# 2026-07-21 rewrite-proxy decision). Never exposed to the browser, so this
# is a plain env var, not NEXT_PUBLIC_.
#
# Local dev: the NestJS backend running on its default port.
# Production (Vercel): the deployed Railway backend's public URL, no
# trailing slash, e.g. https://your-service.up.railway.app
BACKEND_URL="http://localhost:3000"
